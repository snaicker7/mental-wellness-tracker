JOURNAL_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
# Optional: set this to use PostgreSQL instead of the local encrypted file store.
# DATABASE_URL=postgres://user:password@localhost:5432/mental_wellness_tracker?sslmode=disable
JOURNAL_DATA_FILE=data/journals.json
ADDR=:8080
# Comma-separated browser origins allowed to call the API. Local Vite origins are allowed by default.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
